    {
      "featureId": "U01266",
      "sourceLine": 1277,
      "category": "security",
      "bucket": "general",
      "text": "कालबेलिया पोशाक: काले रंग के घाघरे पर की जाने वाली कसीदाकारी का महत्व।",
