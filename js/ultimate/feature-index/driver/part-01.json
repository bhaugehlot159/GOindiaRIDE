      "featureId": "U00332",
      "sourceLine": 333,
      "category": "driver",
      "bucket": "general",
      "text": "लाइव अपडेट: ड्राइवर के पहुँचने का सेकंड-दर-सेकंड समय।",
      "blockKey": "driver-ultimate-u00333-line-333"
    },
    {
      "featureId": "U00333",
      "sourceLine": 334,
      "category": "driver",
      "bucket": "general",
      "text": "दूरी प्रदर्शन: ग्राहक और ड्राइवर के बीच की मीटर में दूरी।",
      "blockKey": "driver-ultimate-u00334-line-334"
    },
    {
      "featureId": "U00337",
      "sourceLine": 338,
      "category": "driver",
      "bucket": "general",
      "text": "शॉर्टकट गाइड: ड्राइवर के लिए संकरी गलियों का रास्ता।",
      "blockKey": "driver-ultimate-u00338-line-338"
    },
    {
      "featureId": "U00343",
      "sourceLine": 344,
      "category": "driver",
      "bucket": "general",
      "text": "पार्किंग अलर्ट: नो-पार्किंग जोन में ड्राइवर को चेतावनी।",
      "blockKey": "driver-ultimate-u00344-line-344"
    },
    {
      "featureId": "U00346",
      "sourceLine": 347,
      "category": "driver",
      "bucket": "general",
      "text": "ड्राइवर फोटो मैसेज: 'मैं यहाँ खड़ा हूँ' का रीयल-टाइम फोटो।",
      "blockKey": "driver-ultimate-u00347-line-347"
    },
    {
      "featureId": "U00350",
      "sourceLine": 351,
      "category": "driver",
      "bucket": "general",
      "text": "ब्रेक सूचना: ड्राइवर के भोजन या फ्यूल ब्रेक की पारदर्शिता।",
      "blockKey": "driver-ultimate-u00351-line-351"
    },
    {
      "featureId": "U00354",
      "sourceLine": 355,
      "category": "driver",
      "bucket": "general",
      "text": "वॉयस गाइड: ड्राइवर के लिए स्थानीय भाषा में निर्देश।",
      "blockKey": "driver-ultimate-u00355-line-355"
    },
    {
      "featureId": "U00379",
      "sourceLine": 380,
      "category": "driver",
      "bucket": "general",
      "text": "नाइट पैकेजेस: रात की लंबी यात्रा के लिए नाइट ड्राइवर।",
      "blockKey": "driver-ultimate-u00380-line-380"
    },
    {
      "featureId": "U00458",
      "sourceLine": 460,
      "category": "driver",
      "bucket": "general",
      "text": "इंस्टेंट प्रीव्यू: बुकिंग से पहले ड्राइवर की असली फोटो और रेटिंग।",
      "blockKey": "driver-ultimate-u00460-line-460"
    },
    {
      "featureId": "U00470",
      "sourceLine": 472,
      "category": "driver",
      "bucket": "general",
      "text": "महिला ड्राइवर: महिला सुरक्षा हेतु विशेष अनुरोध विकल्प।",
      "blockKey": "driver-ultimate-u00472-line-472"
    },
    {
      "featureId": "U00472",
      "sourceLine": 474,
      "category": "driver",
      "bucket": "general",
      "text": "व्हीलचेयर एक्सेस: दिव्यांग सुलभ वाहनों का चयन।",
      "blockKey": "driver-ultimate-u00474-line-474"
    },
    {
      "featureId": "U00475",
      "sourceLine": 477,
      "category": "driver",
      "bucket": "general",
      "text": "वाहन फिटनेस: हर ट्रिप से पहले सफाई और मेंटेनेंस का स्टेटस।",
      "blockKey": "driver-ultimate-u00477-line-477"
    },
    {
      "featureId": "U00484",
      "sourceLine": 486,
      "category": "driver",
      "bucket": "general",
      "text": "छतरी सेवा: बारिश या धूप में ड्राइवर द्वारा छतरी प्रदान करना।",
      "blockKey": "driver-ultimate-u00486-line-486"
    },
    {
      "featureId": "U00490",
      "sourceLine": 492,
      "category": "driver",
      "bucket": "general",
      "text": "ड्राइवर वर्दी: ड्राइवर का राजस्थानी वेशभूषा में होना।",
      "blockKey": "driver-ultimate-u00492-line-492"
    },
    {
      "featureId": "U00498",
      "sourceLine": 500,
      "category": "driver",
      "bucket": "general",
      "text": "विंडशील्ड डिस्प्ले: ड्राइवर के लिए मैप का शीशे पर रिफ्लेक्शन।",
      "blockKey": "driver-ultimate-u00500-line-500"
    },
    {
      "featureId": "U00508",
      "sourceLine": 510,
      "category": "driver",
      "bucket": "general",
      "text": "चेहरे की पहचान: ड्राइवर वेरिफिकेशन के लिए फेस आईडी।",
      "blockKey": "driver-ultimate-u00510-line-510"
    },
    {
      "featureId": "U00515",
      "sourceLine": 517,
      "category": "driver",
      "bucket": "general",
      "text": "ऑटो-असाइनमेंट: सबसे पास और बेस्ट रेटेड ड्राइवर को ट्रिप।",
      "blockKey": "driver-ultimate-u00517-line-517"
    },
    {
      "featureId": "U00517",
      "sourceLine": 520,
      "category": "driver",
      "bucket": "general",
      "text": "वर्चुअल एडमिन: वेबसाइट का ऑटो-मेंटेनेंस और सर्वर हेल्थ की एआई द्वारा निगरानी।",
      "blockKey": "driver-ultimate-u00520-line-520"
    },
    {
      "featureId": "U00519",
      "sourceLine": 522,
      "category": "driver",
      "bucket": "general",
      "text": "बायोमेट्रिक लॉगिन: ग्राहकों और ड्राइवरों के लिए फिंगरप्रिंट या फेस आईडी लॉगिन।",
      "blockKey": "driver-ultimate-u00522-line-522"
    },
    {
      "featureId": "U00520",
      "sourceLine": 523,
      "category": "driver",
      "bucket": "auto-suggestion",
      "text": "फ्यूल ट्रैकिंग: ड्राइवर को सबसे सस्ते और पास के पेट्रोल पंप का एआई सुझाव।",
      "blockKey": "driver-ultimate-u00523-line-523"
    },
    {
      "featureId": "U00521",
      "sourceLine": 524,
      "category": "driver",
      "bucket": "auto-suggestion",
      "text": "ब्रेक अलर्ट: ड्राइवर को थकान होने पर आराम करने का आटोमेटिक सुझाव।",
      "blockKey": "driver-ultimate-u00524-line-524"
    },
    {
      "featureId": "U00526",
      "sourceLine": 529,
      "category": "driver",
      "bucket": "general",
      "text": "ड्राइवर बिहेवियर मॉनिटर: कठोर ब्रेक या तेज़ मोड़ लेने पर ड्राइवर को चेतावनी।",
      "blockKey": "driver-ultimate-u00529-line-529"
    },
    {
      "featureId": "U00530",
      "sourceLine": 533,
      "category": "driver",
      "bucket": "general",
      "text": "स्मार्ट पेआउट: यात्रा खत्म होते ही ड्राइवर के बैंक खाते में पैसा जाना।",
      "blockKey": "driver-ultimate-u00533-line-533"
    },
    {
      "featureId": "U00534",
      "sourceLine": 537,
      "category": "driver",
      "bucket": "general",
      "text": "प्रेडिक्टिव मेंटेनेंस: गाड़ी खराब होने से पहले सर्विसिंग का अलर्ट देना।",
      "blockKey": "driver-ultimate-u00537-line-537"
    },
    {
      "featureId": "U00539",
      "sourceLine": 542,
      "category": "driver",
      "bucket": "general",
      "text": "सेल्फी अटेंडेंस: ड्यूटी शुरू होने से पहले ड्राइवर की वर्दी वाली फोटो।",
      "blockKey": "driver-ultimate-u00542-line-542"
    },
    {
      "featureId": "U00546",
      "sourceLine": 549,
      "category": "driver",
      "bucket": "general",
      "text": "नाइट होल्ड नियम: रात को रुकने पर ड्राइवर के भत्ते का पारदर्शी हिसाब।",
      "blockKey": "driver-ultimate-u00549-line-549"
    },
    {
      "featureId": "U00547",
      "sourceLine": 550,
      "category": "driver",
      "bucket": "general",
      "text": "ड्यूटी लिमिट: ड्राइवर के काम करने के घंटों की सीमा तय करना (सुरक्षा हेतु)।",
      "blockKey": "driver-ultimate-u00550-line-550"
    }
  ]
}
