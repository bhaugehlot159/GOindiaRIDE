    },
    {
      "featureId": "U00785",
      "sourceLine": 790,
      "category": "driver",
      "bucket": "general",
      "text": "इंस्टेंट प्रीव्यू: बुकिंग से पहले गाड़ी की चमक और ड्राइवर का चेहरा दिखाना।",
      "blockKey": "driver-ultimate-u00790-line-790"
    },
    {
      "featureId": "U00788",
      "sourceLine": 793,
      "category": "driver",
      "bucket": "general",
      "text": "इकोनॉमी वाहन: बजट यात्रियों के लिए साफ़-सुथरी कॉम्पैक्ट गाड़ियाँ।",
      "blockKey": "driver-ultimate-u00793-line-793"
