PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/goindiaride
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
FIREBASE_KEY=replace_with_firebase_key
ADMIN_ALLOWED_IPS=127.0.0.1,::1
CORS_ORIGIN=https://goindiaride.in
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RECAPTCHA_SECRET=replace_with_recaptcha_secret

# Advanced hardening
STRICT_SECURITY_MODE=true
MAX_JSON_BODY_KB=128
REQUEST_AUTO_BLOCK_SCORE=85
REQUEST_INCIDENT_SCORE=55
SECURITY_ALLOWED_ORIGINS=https://www.goindiaride.in,https://goindiaride.in
SECURITY_CONTROL_PLANE_SHIELD_ENABLED=true
SECURITY_CONTROL_PLANE_STRICT_SIGNATURE=true
SECURITY_CONTROL_PLANE_ENFORCE_ADMIN_IP=true
SECURITY_CONTROL_PLANE_CRITICAL_RATE_LIMIT_ENABLED=true
SECURITY_CONTROL_PLANE_FAIL_OPEN=false
SECURITY_CONTROL_PLANE_PROTECTED_PREFIXES=/api/security/incidents,/api/security/shield,/api/security/runtime/security,/api/security/policy
IDEMPOTENCY_SHIELD_ENABLED=true
IDEMPOTENCY_SHIELD_REQUIRE_HEADER=true
IDEMPOTENCY_SHIELD_STRICT_PAYLOAD_MATCH=true
IDEMPOTENCY_SHIELD_FAIL_OPEN=false
IDEMPOTENCY_SHIELD_MIN_KEY_LENGTH=16
IDEMPOTENCY_SHIELD_MAX_KEY_LENGTH=128
IDEMPOTENCY_SHIELD_TTL_MS=86400000
IDEMPOTENCY_SHIELD_PROCESSING_TTL_MS=120000
IDEMPOTENCY_SHIELD_PROTECTED_PREFIXES=/api/wallet,/api/wallets,/api/bookings,/api/security/shield,/api/security/runtime/security,/api/security/incidents,/api/security/policy
DENYLIST_SHIELD_ENABLED=true
DENYLIST_SHIELD_FAIL_OPEN=false
DENYLIST_SHIELD_CACHE_TTL_MS=5000
DENYLIST_DEFAULT_DURATION_MS=0
DENYLIST_SHIELD_PROTECTED_PREFIXES=/api/auth,/api/wallet,/api/wallets,/api/bookings,/api/security,/api/admin
ROUTE_GUARD_POLICY_SHIELD_ENABLED=true
ROUTE_GUARD_POLICY_SHIELD_FAIL_OPEN=false
ROUTE_GUARD_POLICY_CACHE_TTL_MS=2000
ROUTE_GUARD_POLICY_BYPASS_PREFIXES=/health,/api/security/csrf-token,/api/security/shield/route-guard
ROUTE_GUARD_POLICY_DEFAULT_DURATION_MS=3600000
ROUTE_GUARD_POLICY_MAX_DURATION_MS=86400000
ADMIN_AUDIT_CHAIN_ENABLED=true
ADMIN_AUDIT_CHAIN_SECRET=replace_with_admin_audit_chain_secret
ADMIN_AUDIT_CHAIN_TRACK_READ_OPS=false
ADMIN_AUDIT_CHAIN_TRACK_PREFIXES=/api/security,/api/admin
ADMIN_AUDIT_CHAIN_MAX_VERIFY_LIMIT=10000
ATTACK_PATTERN_SHIELD_ENABLED=true
ATTACK_PATTERN_SHIELD_FAIL_OPEN=false
ATTACK_PATTERN_SHIELD_FAIL_WINDOW_MS=900000
ATTACK_PATTERN_SHIELD_HIT_MAX=4
ATTACK_PATTERN_SHIELD_QUARANTINE_MS=3600000
ATTACK_PATTERN_SHIELD_QUARANTINE_MAX_MS=86400000
ATTACK_PATTERN_SHIELD_ESCALATION_FACTOR=2
ATTACK_PATTERN_SHIELD_RECORD_TTL_MS=604800000
ATTACK_PATTERN_SHIELD_PROTECTED_PREFIXES=/api/auth,/api/wallet,/api/wallets,/api/bookings,/api/security,/api/admin
GLOBAL_LOCKDOWN_SHIELD_ENABLED=true
GLOBAL_LOCKDOWN_FAIL_OPEN=false
GLOBAL_LOCKDOWN_CACHE_TTL_MS=3000
GLOBAL_LOCKDOWN_LOG_THROTTLE_MS=30000
GLOBAL_LOCKDOWN_BYPASS_PREFIXES=/health,/api/security/csrf-token,/api/security/lockdown/global
GLOBAL_LOCKDOWN_DEFAULT_DURATION_MS=3600000
GLOBAL_LOCKDOWN_MAX_DURATION_MS=86400000
ACCESS_TOKEN_REVOCATION_ENABLED=true
ACCESS_TOKEN_CUTOFF_ENABLED=true
ACCESS_TOKEN_REVOCATION_FAIL_OPEN=false
ACCESS_TOKEN_REVOCATION_DEFAULT_TTL_MS=86400000
ACCESS_TOKEN_REPLAY_SHIELD_ENABLED=true
ACCESS_TOKEN_REPLAY_SHIELD_FAIL_OPEN=false
ACCESS_TOKEN_REPLAY_MAX_DELTA_MS=600000
ACCESS_TOKEN_REPLAY_REQUIRE_FINGERPRINT_CHANGE=true
ACCESS_TOKEN_REPLAY_USER_CUTOFF_ON_DETECT=false
ACCESS_TOKEN_REPLAY_RECORD_TTL_MS=86400000
REFRESH_TOKEN_REPLAY_SHIELD_ENABLED=true
REFRESH_TOKEN_REPLAY_SHIELD_FAIL_OPEN=false
REFRESH_TOKEN_REPLAY_MAX_DELTA_MS=600000
REFRESH_TOKEN_REPLAY_REQUIRE_FINGERPRINT_CHANGE=true
REFRESH_TOKEN_REPLAY_IGNORE_UNKNOWN_COUNTRY=true
REFRESH_TOKEN_REPLAY_RECORD_TTL_MS=2592000000
