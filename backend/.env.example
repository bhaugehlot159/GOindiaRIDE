PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/goindiaride
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
FIREBASE_KEY=replace_with_firebase_key
ADMIN_ALLOWED_IPS=127.0.0.1,::1
CORS_ORIGIN=https://goindiaride.in
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RECAPTCHA_SECRET=replace_with_recaptcha_secret

# Advanced hardening
STRICT_SECURITY_MODE=true
MAX_JSON_BODY_KB=128
REQUEST_AUTO_BLOCK_SCORE=85
REQUEST_INCIDENT_SCORE=55
SECURITY_ALLOWED_ORIGINS=https://www.goindiaride.in,https://goindiaride.in
CSRF_COOKIE_NAME=gir_csrf_token
CSRF_TOKEN_TTL_MINUTES=720
API_SIGNATURE_SECRET=replace_with_api_signature_secret
SECURITY_GATEWAY_ENABLED=true
SECURITY_GATEWAY_MAX_URL_LENGTH=2048
SECURITY_GATEWAY_MAX_HEADER_COUNT=120
SECURITY_GATEWAY_MAX_BODY_DEPTH=10
SECURITY_GATEWAY_MAX_BODY_KEYS=800
SECURITY_GATEWAY_MAX_ARRAY_LENGTH=5000
SECURITY_GATEWAY_MAX_STRING_LENGTH=10000
SECURITY_GATEWAY_REQUIRE_KNOWN_CONTENT_TYPE=true
SECURITY_GATEWAY_PRINCIPAL_FAIL_WINDOW_MS=600000
SECURITY_GATEWAY_PRINCIPAL_FAIL_MAX=15
SECURITY_GATEWAY_PRINCIPAL_BLOCK_MS=1800000
SECURITY_GATEWAY_PRINCIPAL_BLOCK_MAX_MS=86400000
SECURITY_GATEWAY_PRINCIPAL_ESCALATION_FACTOR=2
RECAPTCHA_VERIFY_SERVER_SIDE=true
RECAPTCHA_FAIL_OPEN=false
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_VERIFY_TIMEOUT_MS=3500
AUTH_ABUSE_SHIELD_ENABLED=true
AUTH_ABUSE_PERSISTENT_ENABLED=true
AUTH_ABUSE_PERSISTENT_FAIL_OPEN=true
AUTH_ABUSE_PERSISTENT_RETENTION_MS=1209600000
AUTH_ABUSE_FAIL_WINDOW_MS=900000
AUTH_ABUSE_PRINCIPAL_FAIL_MAX=8
AUTH_ABUSE_IP_FAIL_MAX=25
AUTH_ABUSE_BLOCK_MS=1800000
AUTH_ABUSE_BLOCK_MAX_MS=86400000
AUTH_ABUSE_ESCALATION_FACTOR=2
AUTH_ABUSE_RESET_ON_SUCCESS=true
AUTH_ABUSE_TRACK_PATHS=/api/auth/login,/api/auth/admin/login,/api/auth/register,/api/auth/forgot-password/request,/api/auth/forgot-password/confirm

# Wallet & payment gateway credentials (keep server-side only)
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
STRIPE_SECRET_KEY=sk_live_xxx
PAYPAL_CLIENT_ID=replace_with_paypal_client_id
PAYPAL_CLIENT_SECRET=replace_with_paypal_secret
CASHFREE_APP_ID=replace_with_cashfree_app_id
CASHFREE_SECRET_KEY=replace_with_cashfree_secret
PAYMENT_WEBHOOK_SECRET=replace_with_webhook_secret

# Runtime data mirror (future-business store)
RUNTIME_GIT_SYNC_ENABLED=true
RUNTIME_GIT_SYNC_REMOTE=origin
RUNTIME_GIT_SYNC_TARGET=HEAD
RUNTIME_GIT_SYNC_DEBOUNCE_MS=5000
RUNTIME_EVENTS_ENABLED=true
RUNTIME_EVENT_HASH_SECRET=replace_with_runtime_event_hash_secret
RUNTIME_SNAPSHOTS_ENABLED=true
RUNTIME_SNAPSHOT_HASH_SECRET=replace_with_runtime_snapshot_hash_secret
RUNTIME_AUDIT_MAX_LIMIT=2000
RUNTIME_AUTO_DEDUCT_RATE_WINDOW_MS=600000
RUNTIME_AUTO_DEDUCT_RATE_MAX=20
RUNTIME_AUTO_DEDUCT_FAIL_WINDOW_MS=600000
RUNTIME_AUTO_DEDUCT_FAIL_MAX=10
RUNTIME_AUTO_DEDUCT_BLOCK_MS=1800000
RUNTIME_AUTO_DEDUCT_BLOCK_MAX_MS=86400000
RUNTIME_AUTO_DEDUCT_BLOCK_ESCALATION_WINDOW_MS=86400000
RUNTIME_AUTO_DEDUCT_BLOCK_ESCALATION_FACTOR=2
RUNTIME_AUTO_DEDUCT_INTEGRITY_BLOCK_MS=14400000
RUNTIME_AUTO_DEDUCT_RISK_DENY_THRESHOLD=85
RUNTIME_SECURITY_LOCKDOWN_MAX_MS=86400000
RUNTIME_REFERENCE_REPLAY_WINDOW_MS=86400000
RUNTIME_REFERENCE_QUARANTINE_MS=21600000
RUNTIME_REFERENCE_QUARANTINE_MAX_MS=259200000
RUNTIME_ACTOR_FAIL_WINDOW_MS=600000
RUNTIME_ACTOR_FAIL_MAX=12
RUNTIME_ACTOR_COOLDOWN_MS=1800000
RUNTIME_ACTOR_COOLDOWN_MAX_MS=86400000
RUNTIME_ACTOR_COOLDOWN_ESCALATION_FACTOR=2

# Wallet critical security
WALLET_STRICT_SIGNATURE=true
BOOKING_STRICT_SIGNATURE=true
BOOKING_CRITICAL_RATE_LIMIT_ENABLED=true
BOOKING_SIGNATURE_INCLUDE_CREATE=true
RUNTIME_AUTO_DEDUCT_REQUIRE_OTP=true
RUNTIME_AUTO_DEDUCT_HIGH_VALUE=50000
AUTO_DEDUCT_REF_MIN_LENGTH=8
AUTO_DEDUCT_HASH_SECRET=replace_with_auto_deduct_integrity_secret
WALLET_CONFIRM_LOCK_TTL_MS=180000
WALLET_REVIEW_LOCK_TTL_MS=180000

