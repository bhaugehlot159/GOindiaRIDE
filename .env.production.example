# GOindiaRIDE Production Environment Template
# Copy this file to .env.production and fill in all required values
# NEVER commit the actual .env.production file to version control

# ========================================
# CRITICAL VARIABLES (Must be set)
# ========================================

# Node Environment - MUST be set to "production" for security
NODE_ENV=production

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# Get from: MongoDB Atlas dashboard
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/goindiaride

# Firebase Configuration
# Get from: Firebase Console > Project Settings > Web App Config
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# JWT Secrets (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# MINIMUM 32 characters each - Use strong, random values
JWT_SECRET=your_jwt_secret_min_32_chars_long_random_value_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_long_random_value_here

# WhatsApp Webhook Configuration
# Get webhook token from: Meta/WhatsApp Business Platform
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_API_ACCESS_TOKEN=your_whatsapp_api_access_token

# ========================================
# RECOMMENDED VARIABLES (Security)
# ========================================

# CORS Configuration
# Set to your production domain
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
# Requests per 15-minute window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_min_32_chars_long_random_value_here
SESSION_TIMEOUT_MS=3600000

# API Request Signing (for inter-service communication)
REQUEST_SIGNATURE_SECRET=your_request_signature_secret_here
REQUEST_SIGNATURE_SALT=your_request_signature_salt_here

# ========================================
# OPTIONAL VARIABLES (Features & Monitoring)
# ========================================

# Email Configuration (for notifications)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@yourdomain.com

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Twilio Configuration (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Configuration (alternative email)
SENDGRID_API_KEY=your_sendgrid_api_key

# Stripe Configuration (for payments)
STRIPE_PUBLIC_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Logging & Monitoring
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/goindiaride/app.log
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Database Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 2 * * *
DB_BACKUP_RETENTION_DAYS=30

# ========================================
# DIAGNOSTIC VARIABLES (Optional, remove for prod)
# ========================================
# These should be removed or disabled in production
DIAGNOSTIC_TEST_EMAIL=admin@example.com
DIAGNOSTIC_TEST_PASSWORD=your_diagnostic_password

# ========================================
# INTERNAL VARIABLES (Auto-configured)
# ========================================
PORT=5000
API_VERSION=v1
SERVICE_NAME=GOindiaRIDE API

# ========================================
# IMPORTANT NOTES
# ========================================
# 1. All values must be URL-encoded if they contain special characters
# 2. Never use single quotes - values must be unquoted or in double quotes
# 3. Generate secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 4. Keep this file in a secure location - use secrets manager in production
# 5. Rotate secrets every 90 days
# 6. Use different values for staging and production
# 7. For MongoDB Atlas: whitelist production server IPs only
